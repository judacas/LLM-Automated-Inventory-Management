# Azure AI Foundry configuration template. Copy to `.env` and populate.
#
# Required values
AZURE_AI_PROJECT_ENDPOINT=https://<your-ai-services>.services.ai.azure.com/api/projects/<your-project>

# Directory containing `*_agent.toml` definitions. Defaults to `agents/` if omitted.
A2A_AGENT_CONFIG_DIR=agents

# Optional fallback if `foundry.agent_name` is not set in an agent definition.
AZURE_AI_AGENT_NAME=

# Optional overrides
A2A_HOST=localhost
A2A_PORT=10007
# Set to "local" for direct access, or "forwarded" if behind reverse proxy
A2A_URL_MODE=local
# required if A2A_URL_MODE=forwarded
A2A_FORWARDED_BASE_URL=
LOG_LEVEL=INFO
