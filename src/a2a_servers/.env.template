# Azure AI Foundry configuration template. Copy to `.env` and populate.
#
# Required values
AZURE_AI_PROJECT_ENDPOINT=https://<your-ai-services>.services.ai.azure.com/api/projects/<your-project>

# Agent Configuration Source
# Set to "true" to load agent configs from Azure Blob Storage instead of local filesystem
AZURE_BLOB_CONFIG_SOURCE=false

# Azure Blob Storage configuration (only used if AZURE_BLOB_CONFIG_SOURCE=true)
# Use either connection string OR managed identity (account URL)
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_ACCOUNT_URL=https://<storage-account-name>.blob.core.windows.net
AZURE_BLOB_CONTAINER_NAME=agent-configs
AZURE_BLOB_PREFIX=

# Directory containing `*_agent.toml` definitions. Defaults to `agents/` if omitted.
# Only used if AZURE_BLOB_CONFIG_SOURCE=false
A2A_AGENT_CONFIG_DIR=agents

# Optional overrides
A2A_HOST=localhost
A2A_PORT=10007
# Set to "local" for direct access, or "forwarded" if behind reverse proxy
A2A_URL_MODE=local
# required if A2A_URL_MODE=forwarded
A2A_FORWARDED_BASE_URL=
LOG_LEVEL=INFO
