# Azure AI Foundry configuration template. Copy to `.env` and populate.
#
# Required values
AZURE_AI_PROJECT_ENDPOINT=https://<your-ai-services>.services.ai.azure.com/api/projects/<your-project>

# --- Agent config source (choose one) ---
#
# Option A – LOCAL DIRECTORY (default, good for local development)
# Directory containing `*_agent.toml` definitions. Defaults to `agents/` if omitted.
A2A_AGENT_CONFIG_DIR=agents

# Option B – AZURE BLOB STORAGE (recommended for production)
# Full URL of the Blob Storage container holding `*_agent.toml` files.
# When set, A2A_AGENT_CONFIG_DIR is ignored.
# Production example (uses DefaultAzureCredential / managed identity):
#   A2A_AGENT_CONFIG_BLOB_URL=https://<account>.blob.core.windows.net/<container>
# Local testing with Azurite example:
#   A2A_AGENT_CONFIG_BLOB_URL=http://127.0.0.1:10000/devstoreaccount1/agent-configs
A2A_AGENT_CONFIG_BLOB_URL=

# Connection string for blob access (optional).
# Required when using Azurite locally (see docs/remote-agent-configs.md).
# Leave blank in Azure App Service – DefaultAzureCredential is used instead.
A2A_AGENT_CONFIG_BLOB_CONN_STR=

# Optional overrides
A2A_HOST=localhost
A2A_PORT=10007
# Set to "local" for direct access, or "forwarded" if behind reverse proxy
A2A_URL_MODE=local
# required if A2A_URL_MODE=forwarded
A2A_FORWARDED_BASE_URL=
LOG_LEVEL=INFO
