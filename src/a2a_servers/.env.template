# Azure AI Foundry configuration template. Copy to `.env` and populate.
#
# Required values
AZURE_AI_PROJECT_ENDPOINT=https://<your-ai-services>.services.ai.azure.com/api/projects/<your-project>

# Directory containing `*_agent.toml` definitions. Defaults to `agents/` if omitted.
# Ignored when AZURE_STORAGE_CONNECTION_STRING or AZURE_STORAGE_ACCOUNT_URL is set.
A2A_AGENT_CONFIG_DIR=agents

# --- Azure Table Storage (database-backed agent definitions) ---
# Set one of these to load agent definitions from Azure Table Storage instead of
# local TOML files. Leave both empty to fall back to file-based loading.
#
# Option A – connection string (dev / simple deployments):
AZURE_STORAGE_CONNECTION_STRING=
#
# Option B – account URL with managed identity (recommended for Azure production):
AZURE_STORAGE_ACCOUNT_URL=https://<your-storage-account>.table.core.windows.net
#
# Name of the Azure Storage table that holds agent records. Default: a2aagents
A2A_AGENTS_TABLE=a2aagents

# Optional overrides
A2A_HOST=localhost
A2A_PORT=10007
# Set to "local" for direct access, or "forwarded" if behind reverse proxy
A2A_URL_MODE=local
# required if A2A_URL_MODE=forwarded
A2A_FORWARDED_BASE_URL=
LOG_LEVEL=INFO
