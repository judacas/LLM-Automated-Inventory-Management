# Required — JWT signing key (any long random string)
JWT_SECRET=replace_me_with_a_long_random_string

# Required — Azure AI Foundry agent
PROJECT_ENDPOINT=https://<your-resource>.services.ai.azure.com/api/projects/<project-name>
AGENT_NAME=adminOrchestrator

# Required — Azure SQL (for Response Evaluations & Logs)
AZURE_SQL_SERVER=your-server.database.windows.net
AZURE_SQL_DATABASE=your-db
AZURE_SQL_USERNAME=your-user
AZURE_SQL_PASSWORD=your-password

# Required — Azure Monitor / Application Insights
APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=...;IngestionEndpoint=...
AZURE_LOG_WORKSPACE_ID=your-workspace-id

# Optional — MCP service base URL (for dashboard metrics and tool endpoints)
MCP_BASE_URL=https://<your-mcp-app>.azurewebsites.net/mcp
